# 运行模式: once 或 schedule
RUN_MODE=schedule
SCHEDULE_INTERVAL=21600

# ========== 新增：CDN 代理控制 ==========
# 是否启用 CDN 代理加速（默认 true）
# 本地 Docker 环境如果遇到代理问题，设置为 false
ENABLE_CDN_PROXY=true

# 性能配置
MAX_WORKERS=20
TIMEOUT=8

# 验证配置
FFMPEG_ENABLE=true

# ========== ffmpeg 模式 ==========
# deep: 深度验证（默认） | quick: 快速验证（仅HTTP） | off: 禁用
FFMPEG_MODE=deep
# ffprobe 结果缓存时长（小时），默认7天
FFPROBE_CACHE_HOURS=168

# 缓存时长（小时）
CACHE_HOURS=24

# 每个频道保留的源数量（用于自动切换）
MAX_SOURCES_PER_CHANNEL=3

# 输出配置
DEMO_MATCH_MODE=contains

# 功能开关
ENABLE_DEMO_FILTER=true
ENABLE_ALIAS=true
ENABLE_BLACKLIST=true
DATABASE_ENABLE=true

# Web 服务
WEB_SERVER_PORT=8080

# ========== 缓存优化配置 ==========
CACHE_RAW_HOURS=48
CACHE_SPEED_HOURS=24
ENABLE_INCREMENTAL_FETCH=true

# ========== EPG 配置 ==========
ENABLE_EPG_INJECTION=true
EPG_CACHE_DAYS=7

# ========== 输出格式配置 ==========
ENABLE_JSON_OUTPUT=true
ENABLE_LITE_VERSION=true
ENABLE_EPG_OUTPUT=true

# ========== 自治模式配置 ==========
AUTONOMOUS_MODE=false
AUTO_UPDATE_STABLE=true
AUTO_REPLACE_FAILED=true
QUALITY_CHECK_INTERVAL=24
CANDIDATE_OBSERVATION_HOURS=24
CANDIDATE_MIN_SUCCESS=10
CANDIDATE_MIN_SUCCESS_RATE=0.8
CANDIDATE_MAX_LATENCY=2000

# ========== 动态并发配置 ==========
DYNAMIC_CONCURRENCY=true
MIN_WORKERS=5
MAX_WORKERS=20

# ========== 布隆过滤器配置 ==========
ENABLE_BLOOM_FILTER=true
BLOOM_FILTER_CAPACITY=100000

# Web 管理界面
WEB_UI_ENABLE=true
WEB_UI_TITLE=IPTV 智能管理面板
