        'src.core.config',
        'src.core.run',
        'src.core.fetcher',
        'src.core.parser',
        'src.core.speed_tester',
        'src.core.ffmpeg_validator',
        'src.core.merger',
        'src.core.generator',
        'src.core.demo_filter',
        'src.core.classifier',
        'src.core.blacklist_filter',
        'src.core.database',
        'src.core.logger',
        'src.core.alias_matcher',
        'src.core.fixed_sources',
        'src.core.stable',
        'src.core.stable.manager',
        'src.core.source_pool',
        'src.core.source_pool.discoverer',
        'src.core.candidate',
