        'src.core.global_channels',
        'src.core.generator_enhanced',
        'src.core.overseas_filter',
        'src.core.special_categories',
        'src.core.orchestrator',
        'src.gui',
        'src.gui.main_window',
        'src.gui.widgets',
        'src.gui.styles',
